  "quality_engine": {
    "day_selection": {
      "min_samples": 1,
      "max_labels": 1
    },
    "status_filter": {
      "exclude_noise_keywords": [
        "时价",
        "国补",
        "补贴",
        "店补",
        "平台补贴",
        "以旧换新"
      ]
    },
    "retention": {
      "sparse_min_keep": 4,
      "sparse_max_trim": 1,
      "balanced_min_keep": 4,
      "balanced_keep_ratio": 0.65,
      "dense_min_keep": 5,
      "dense_keep_ratio": 0.45
    },
    "outlier_profiles": {
      "balanced": {
        "modified_zscore": {
          "enabled": true,
          "threshold": 4.0,
          "min_gap_floor": 140,
          "min_gap_ratio": 0.02
        },
        "iqr": {
          "enabled": true,
          "fence_multiplier": 2.4,
          "min_gap_floor": 140,
          "min_gap_ratio": 0.02
        },
        "cluster_tail": {
          "enabled": false
        }
      },
      "dense": {
        "modified_zscore": {
          "enabled": true,
          "threshold": 3.5,
          "min_gap_floor": 120,
          "min_gap_ratio": 0.018
        },
        "iqr": {
          "enabled": true,
          "fence_multiplier": 2.0,
          "min_gap_floor": 120,
          "min_gap_ratio": 0.018
        },
        "cluster_tail": {
          "enabled": true
        }
      }
    },
    "interval_generation": {
      "single_quote_mode": "exact",
      "single_quote_padding_floor": 0,
      "single_quote_padding_ratio": 0.0,
      "sparse_minmax_max_count": 3,
      "iqr_min_sample_count": 4
    },
    "scoring": {
      "count_weight": 14.0,
      "spread_penalty_divisor": 18.0,
      "reference_penalty_divisor": 45.0,
      "reference_penalty_cap": 2000,
      "single_sample_penalty": 14.0,
      "two_sample_penalty": 6.0,
      "status_priority": {
        "apple_exact": 36,
        "apple_nationwide": 30,
        "apple_contains_company_pure_sealed": 22,
        "apple_other": 0,
        "default_with_status": 10,
        "default_without_status": 6
      }
    }
  },
  "reporting": {
    "task_status_groups": {
      "terminal_success": [
        "ok",
        "zero_row"
      ],
      "terminal_failure": [
        "error",
        "exception",
        "persistence_error"
      ],
      "skipped": [
        "skipped_done",
        "skipped_blacklist"
      ]
    },
    "row_drop_reasons": [
      "drop_by_date",
      "drop_out_of_stock",
      "drop_by_activation_field",
      "drop_by_global_dstatus",
      "drop_by_apple_dstatus",
      "drop_by_non_apple_dstatus",
      "drop_invalid_price"
    ],
    "gap_event_types": [
      "gap_detected",
      "gap_unresolved",
      "gap_resolved"
    ]
  }
}
