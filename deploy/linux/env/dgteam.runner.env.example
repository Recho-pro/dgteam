# GitHub repository that should own the trusted runner, for example owner/repo.
DGTEAM_GITHUB_REPOSITORY=

# Stable runner identity shown in GitHub Actions.
DGTEAM_GITHUB_RUNNER_NAME=dgteam-trusted-live
DGTEAM_GITHUB_RUNNER_LABELS=self-hosted,dgteam-trusted,linux,x64
DGTEAM_GITHUB_RUNNER_GROUP=Default

# Runtime layout on the live host.
DGTEAM_GITHUB_RUNNER_ROOT=/srv/dgteam/runtime/cloud/github_runner
DGTEAM_GITHUB_RUNNER_WORKDIR=/srv/dgteam/runtime/cloud/github_runner/_work

# Current trusted real-source gate truth. Round 27 may revise this path, but
# the runner, workflow, and local dry-run should stay aligned until then.
DGTEAM_TRUSTED_RUNNER_SOURCE_DB=/srv/dgteam/runtime/cloud/current/dgteam.db

# Optional override when GitHub's latest release API is blocked or mirrored.
DGTEAM_GITHUB_RUNNER_ASSET_URL=
