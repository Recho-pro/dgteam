DGTEAM_ENV=production
DGTEAM_LOG_LEVEL=INFO
DGTEAM_PROJECT_ROOT=/srv/dgteam
DGTEAM_PYTHON_BIN=/srv/dgteam/.venv/bin/python
DGTEAM_BACKUP_ROOT=/var/backups/dgteam

DGTEAM_LOCAL_ROOT=./runtime/local
DGTEAM_CLOUD_ROOT=./runtime/cloud

DGTEAM_DB_PATH=./runtime/cloud/current/dgteam.db
DGTEAM_RULES_PATH=./rules/default_rules.json
DGTEAM_BLACKLIST_PATH=./config/model_blacklist.csv
DGTEAM_BASE_URL=http://web.yilaitong.net

DGTEAM_QUERY_HOST=127.0.0.1
DGTEAM_QUERY_PORT=9765

DGTEAM_PUBLISH_HOST=127.0.0.1
DGTEAM_PUBLISH_PORT=9865
DGTEAM_PUBLISH_TOKEN=replace-with-a-long-random-token
DGTEAM_PUBLISH_UPLOADS_DIR=./runtime/cloud/uploads

DGTEAM_WECHAT_OFFICIAL_ENABLED=true
DGTEAM_WECHAT_OFFICIAL_HOST=127.0.0.1
DGTEAM_WECHAT_OFFICIAL_PORT=8975
DGTEAM_WECHAT_OFFICIAL_CALLBACK_PATH=/wechat/official/callback
DGTEAM_WECHAT_OFFICIAL_APP_ID=
DGTEAM_WECHAT_OFFICIAL_APP_SECRET=
DGTEAM_WECHAT_OFFICIAL_TOKEN=
DGTEAM_WECHAT_OFFICIAL_ENCODING_AES_KEY=
DGTEAM_WECHAT_OFFICIAL_API_BASE_URL=https://api.weixin.qq.com
DGTEAM_WECHAT_OFFICIAL_STATE_DIR=./runtime/local/wechat_official/state
DGTEAM_WECHAT_OFFICIAL_IMAGE_WORKER_ENABLED=true
DGTEAM_WECHAT_OFFICIAL_IMAGE_API_KEY=
DGTEAM_WECHAT_OFFICIAL_IMAGE_FAST_MODEL=openai/gpt-4.1-mini
DGTEAM_WECHAT_OFFICIAL_IMAGE_FAST_TIMEOUT_SECONDS=4
DGTEAM_WECHAT_OFFICIAL_IMAGE_FAST_MAX_EDGE_PX=768
DGTEAM_WECHAT_OFFICIAL_IMAGE_FAST_MAX_BYTES=140000
DGTEAM_WECHAT_OFFICIAL_IMAGE_FAST_JPEG_QUALITY=68
DGTEAM_WECHAT_OFFICIAL_IMAGE_PRIMARY_MODEL=qwen/qwen3-vl-32b-instruct
DGTEAM_WECHAT_OFFICIAL_IMAGE_FALLBACK_MODEL=qwen/qwen3-vl-235b-a22b-instruct
DGTEAM_WECHAT_OFFICIAL_IMAGE_POLL_INTERVAL_SECONDS=2
DGTEAM_WECHAT_OFFICIAL_IMAGE_TIMEOUT_SECONDS=45
DGTEAM_WECHAT_OFFICIAL_IMAGE_MAX_EDGE_PX=960
DGTEAM_WECHAT_OFFICIAL_IMAGE_MAX_BYTES=240000
DGTEAM_WECHAT_OFFICIAL_IMAGE_JPEG_QUALITY=70

DGTEAM_WECHAT_CLAWBOT_ENABLED=false
DGTEAM_WECHAT_CLAWBOT_MODE=wecom_customer_service
DGTEAM_WECHAT_CLAWBOT_HOST=127.0.0.1
DGTEAM_WECHAT_CLAWBOT_PORT=8965
DGTEAM_WECHAT_CLAWBOT_CALLBACK_PATH=/wecom/kf/callback
DGTEAM_WECHAT_CLAWBOT_SECRET=
DGTEAM_WECHAT_CLAWBOT_CORP_ID=
DGTEAM_WECHAT_CLAWBOT_CORP_SECRET=
DGTEAM_WECHAT_CLAWBOT_TOKEN=
DGTEAM_WECHAT_CLAWBOT_ENCODING_AES_KEY=
DGTEAM_WECHAT_CLAWBOT_OPEN_KFID=
DGTEAM_WECHAT_CLAWBOT_API_BASE_URL=https://qyapi.weixin.qq.com
DGTEAM_WECHAT_CLAWBOT_INBOX_DIR=./runtime/local/wechat_clawbot/inbox
DGTEAM_WECHAT_CLAWBOT_ARCHIVE_DIR=./runtime/local/wechat_clawbot/archive
DGTEAM_WECHAT_CLAWBOT_STATE_DIR=./runtime/local/wechat_clawbot/state

DGTEAM_RELEASE_CURRENT=./runtime/cloud/current
DGTEAM_RELEASE_PREVIOUS=./runtime/cloud/previous
DGTEAM_RELEASE_HISTORY=./runtime/cloud/releases
DGTEAM_RELEASE_STAGING=./runtime/cloud/staging
DGTEAM_RELEASE_STATE_DIR=./runtime/cloud/deployments

DGTEAM_RETENTION_ENABLED=true
DGTEAM_KEEP_LOCAL_RELEASES=1
DGTEAM_KEEP_LOCAL_RELEASE_ARCHIVES=0
DGTEAM_KEEP_INTEGRATION_SMOKE_RUNS=3
DGTEAM_KEEP_CLOUD_RELEASES=1
DGTEAM_KEEP_CLOUD_ROLLBACKS=1
DGTEAM_PRUNE_CLOUD_UPLOADS=true
DGTEAM_KEEP_CLOUD_DEPLOYMENTS=20
DGTEAM_KEEP_AUTOMATION_RUN_STATES=30
DGTEAM_KEEP_AUTOMATION_RECOVERY_STATES=10
DGTEAM_MAX_STAGING_AGE_HOURS=6
DGTEAM_MAX_UPLOAD_AGE_HOURS=24

DGTEAM_PUBLIC_STATUS_URL=https://dgtdnb.com/api/status
DGTEAM_RUN_RUNTIME_AUDIT=true
DGTEAM_DISK_WARN_PERCENT=80
DGTEAM_MAX_BACKUP_AGE_HOURS=30
DGTEAM_MAX_WORKER_BACKLOG=10
DGTEAM_MAX_FAILED_TASKS=0
DGTEAM_ALERT_WEBHOOK_URL=

DGTEAM_OPENROUTER_API_KEY=
